# ============================================================================
# ROTAS NORDESTINAS - Variáveis de Ambiente (EXEMPLO)
# ============================================================================
# Copie este arquivo para .env.local na raiz e em backend/.env
# Preencha com suas credenciais do Supabase
# ============================================================================

# ============================================================================
# SUPABASE - Credenciais do Projeto
# ============================================================================
# Encontre esses valores em: Supabase Dashboard > Settings > API
# Ou em: Supabase Dashboard > Project Settings > API

# URL do seu projeto Supabase
# Exemplo: https://abcdefghijklmnopqrst.supabase.co
NEXT_PUBLIC_SUPABASE_URL=sua_url_do_supabase

# Chave anônima (pública) do Supabase - segura para usar no frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_do_supabase

# Chave de service role (NUNCA expor no frontend!)
# Usada apenas no backend e em server-side para operações administrativas
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role

# ============================================================================
# API - URLs
# ============================================================================

# URL base da API do backend (Next.js ou Express)
# Para Next.js em dev: http://localhost:3000
# Para Express em dev: http://localhost:5000 (backend Express separado)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Porta do servidor Express (backend)
PORT=5000

# ============================================================================
# SUPABASE STORAGE - Bucket para upload de imagens
# ============================================================================
# Crie um bucket público chamado "imagens-rotas" no Supabase Dashboard > Storage
# E configure as políticas RLS para permitir upload público
